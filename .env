# Application
APP_NAME="Autism Therapy Management System"
APP_VERSION="1.0.0"
DEBUG=False

# Database
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/autism_therapy

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production-with-a-strong-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost", "http://localhost:5173","http://127.0.0.1:5173"]

# Logging
LOG_LEVEL=INFO
